            "content": "\npackage main\n\nimport \"fmt\"\n\nfunc media(vetor []float64) float64 {\n\tsoma := 0.0\n\n\tfor i := 0; i < len(vetor); i++ {\n\t\tsoma += vetor[i]\n\t}\n\n\treturn soma / float64(len(vetor))\n}\n\nfunc soldado(vetor []float64) {\n\tm := media(vetor)\n\n\tfor i := 0; i < len(vetor); i++ {\n\t\tif vetor[i] < m {\n\t\t\tfmt.Print(\"P\")\n\t\t} else if vetor[i] == m {\n\t\t\tfmt.Print(\"M\")\n\t\t} else {\n\t\t\tfmt.Print(\"G\")\n\t\t}\n\n\t\tif i < len(vetor)-1 {\n\t\t\tfmt.Print(\" \")\n\t\t}\n\t}\n\n\tfmt.Println()\n}\n\nfunc main() {\n\tvar qtd int\n\tfmt.Scan(&qtd)\n\n\tvetor := make([]float64, qtd)\n\n\tfor i := 0; i < qtd; i++ {\n\t\tfmt.Scan(&vetor[i])\n\t}\n\n\tfmt.Printf(\"%.2f\\n\", media(vetor))\n\tsoldado(vetor)\n}\n",
